<div
  id="cookie-banner"
  class="cookie-banner"
  data-gtm-container-id="GTM-T859CMW"
  aria-hidden="true"
  role="dialog"
  aria-modal="true"
  aria-label="Cookie consent"
>
  <div class="cookie-banner__backdrop"></div>
  <div class="cookie-banner__inner">
    <div class="cookie-banner__panel" data-cookie-panel="main">
      <p class="cookie-banner__eyebrow">Privacy choices</p>
      <h2 class="cookie-banner__title">Help us improve The Watch Resource</h2>
      <p class="cookie-banner__text">
        We use cookies to understand which reviews, guides, and comparison pages help readers most so we can improve
        the site. You can accept analytics cookies, use essential cookies only, or manage your preferences.
        <a href="/pages/privacy-policy/" class="cookie-banner__link">Privacy Policy</a>
      </p>
      <p class="cookie-banner__note">We do not use advertising cookies in this banner. Analytics is used only to measure site performance and improve content.</p>
      <div class="cookie-banner__actions">
        <button id="cookie-accept-all" class="cookie-btn cookie-btn--primary" type="button">Accept All</button>
        <button id="cookie-accept-necessary" class="cookie-btn cookie-btn--outline" type="button">Use Essential Only</button>
        <button id="cookie-settings" class="cookie-btn cookie-btn--ghost" type="button">Manage Preferences</button>
      </div>
    </div>

    <div class="cookie-banner__panel" data-cookie-panel="settings" hidden>
      <p class="cookie-banner__eyebrow">Manage preferences</p>
      <h2 class="cookie-banner__title">Choose which cookies you want to allow</h2>
      <p class="cookie-banner__text">
        Necessary cookies are always on because they keep the site functioning properly. Analytics stays off until you
        choose to enable it.
      </p>
      <div class="cookie-options">
        <label class="cookie-option">
          <span class="cookie-option__copy">
            <span class="cookie-option__title">Necessary</span>
            <span class="cookie-option__description">Required for core site functionality and storing your consent choice.</span>
          </span>
          <input type="checkbox" checked disabled />
        </label>

        <label class="cookie-option">
          <span class="cookie-option__copy">
            <span class="cookie-option__title">Analytics</span>
            <span class="cookie-option__description">Optional cookies used by Google Analytics 4 to understand which pages perform well, improve navigation, and make our content more useful.</span>
          </span>
          <input id="cookie-analytics" type="checkbox" />
        </label>
      </div>
      <div class="cookie-banner__actions cookie-banner__actions--settings">
        <button id="cookie-save-preferences" class="cookie-btn cookie-btn--primary" type="button">Save Preferences</button>
        <button id="cookie-back" class="cookie-btn cookie-btn--ghost" type="button">Back</button>
      </div>
    </div>
  </div>
</div>

<script is:inline>
  (function () {
    var STORAGE_KEY = 'twr_cookie_consent';
    var banner = document.getElementById('cookie-banner');
    var mainPanel = banner && banner.querySelector('[data-cookie-panel="main"]');
    var settingsPanel = banner && banner.querySelector('[data-cookie-panel="settings"]');
    var acceptAllButton = document.getElementById('cookie-accept-all');
    var acceptNecessaryButton = document.getElementById('cookie-accept-necessary');
    var settingsButton = document.getElementById('cookie-settings');
    var savePreferencesButton = document.getElementById('cookie-save-preferences');
    var backButton = document.getElementById('cookie-back');
    var analyticsInput = document.getElementById('cookie-analytics');
    var gtmContainerId = banner && banner.getAttribute('data-gtm-container-id');
    var gtmLoaded = Boolean(window.__twrGtmLoaded);
    var isLocalhost = window.location.hostname === 'localhost' || window.location.hostname === '127.0.0.1';

    if (
      !(banner instanceof HTMLElement) ||
      !(mainPanel instanceof HTMLElement) ||
      !(settingsPanel instanceof HTMLElement) ||
      !(acceptAllButton instanceof HTMLButtonElement) ||
      !(acceptNecessaryButton instanceof HTMLButtonElement) ||
      !(settingsButton instanceof HTMLButtonElement) ||
      !(savePreferencesButton instanceof HTMLButtonElement) ||
      !(backButton instanceof HTMLButtonElement) ||
      !(analyticsInput instanceof HTMLInputElement)
    ) {
      return;
    }

    function debugLog() {
      if (!isLocalhost) {
        return;
      }

      var args = Array.prototype.slice.call(arguments);
      args.unshift('[TWR consent]');
      console.info.apply(console, args);
    }

    function readConsent() {
      var stored = localStorage.getItem(STORAGE_KEY);
      if (!stored) {
        return null;
      }

      try {
        return normalizeConsent(JSON.parse(stored));
      } catch (error) {
        if (stored === 'accepted') {
          return { necessary: true, analytics: true };
        }

        if (stored === 'declined') {
          return { necessary: true, analytics: false };
        }

        localStorage.removeItem(STORAGE_KEY);
        return null;
      }
    }

    function writeConsent(consent) {
      localStorage.setItem(STORAGE_KEY, JSON.stringify(consent));
    }

    function normalizeConsent(consent) {
      if (!consent || typeof consent !== 'object') {
        return null;
      }

      return {
        necessary: true,
        analytics: Boolean(consent.analytics)
      };
    }

    function syncInputs(consent) {
      analyticsInput.checked = Boolean(consent && consent.analytics);
    }

    function showPanel(panel) {
      var showingSettings = panel === 'settings';
      mainPanel.hidden = showingSettings;
      settingsPanel.hidden = !showingSettings;
    }

    function openBanner(panel) {
      syncInputs(readConsent());
      showPanel(panel || 'main');
      banner.removeAttribute('aria-hidden');
      document.body.classList.add('cookie-banner-open');
    }

    function closeBanner() {
      banner.setAttribute('aria-hidden', 'true');
      document.body.classList.remove('cookie-banner-open');
    }

    function loadGTM() {
      if (gtmLoaded || !gtmContainerId) {
        if (!gtmContainerId) {
          debugLog('GTM container ID missing, skipping load.');
        } else {
          debugLog('GTM already loaded, skipping duplicate load.');
        }
        return;
      }

      gtmLoaded = true;
      window.dataLayer = window.dataLayer || [];
      debugLog('Analytics consent granted.');
      debugLog('Loading GTM:', gtmContainerId);

      if (typeof window.twrLoadGTM === 'function') {
        window.twrLoadGTM();
        return;
      }

      window.dataLayer.push({
        'gtm.start': new Date().getTime(),
        event: 'gtm.js'
      });

      var script = document.createElement('script');
      script.async = true;
      script.src = 'https://www.googletagmanager.com/gtm.js?id=' + encodeURIComponent(gtmContainerId);
      document.head.appendChild(script);
    }

    function applyTrackingConsent(consent) {
      if (consent.analytics) {
        if (typeof window.gtag === 'function') {
          window.gtag('consent', 'update', {
            analytics_storage: 'granted',
            ad_storage: 'denied',
            ad_user_data: 'denied',
            ad_personalization: 'denied',
            personalization_storage: 'denied'
          });
        }

        loadGTM();
      } else {
        if (typeof window.gtag === 'function') {
          window.gtag('consent', 'update', {
            analytics_storage: 'denied',
            ad_storage: 'denied',
            ad_user_data: 'denied',
            ad_personalization: 'denied',
            personalization_storage: 'denied'
          });
        }

        debugLog('Analytics consent denied. GTM remains loaded in advanced consent mode.');
      }
    }

    function applyConsent(consent) {
      writeConsent(consent);
      applyTrackingConsent(consent);
      closeBanner();
    }

    function shouldRequireAnalyticsConsentByTimezone() {
      var timezone = '';

      try {
        timezone = Intl.DateTimeFormat().resolvedOptions().timeZone || '';
      } catch (_) {}

      if (!timezone) return true;
      if (timezone.indexOf('Europe/') === 0) return true;

      return [
        'Atlantic/Azores',
        'Atlantic/Canary',
        'Atlantic/Faroe',
        'Atlantic/Madeira',
        'Atlantic/Reykjavik'
      ].indexOf(timezone) !== -1;
    }

    var storedConsent = readConsent();
    if (storedConsent) {
      syncInputs(storedConsent);
      applyTrackingConsent(storedConsent);
      closeBanner();
    } else if (!shouldRequireAnalyticsConsentByTimezone()) {
      syncInputs({ necessary: true, analytics: true });
      applyTrackingConsent({ necessary: true, analytics: true });
      closeBanner();
    } else {
      openBanner('main');
    }

    acceptAllButton.addEventListener('click', function () {
      applyConsent({ necessary: true, analytics: true });
    });

    acceptNecessaryButton.addEventListener('click', function () {
      applyConsent({ necessary: true, analytics: false });
    });

    settingsButton.addEventListener('click', function () {
      openBanner('settings');
    });

    backButton.addEventListener('click', function () {
      showPanel('main');
    });

    savePreferencesButton.addEventListener('click', function () {
      applyConsent({
        necessary: true,
        analytics: analyticsInput.checked
      });
    });

    document.addEventListener('twr:open-cookie-settings', function () {
      openBanner('settings');
    });

    document.addEventListener('click', function (event) {
      var target = event.target;
      if (!(target instanceof HTMLElement)) {
        return;
      }

      if (target.closest('[data-open-cookie-settings]')) {
        event.preventDefault();
        openBanner('settings');
      }
    });
  })();
</script>

<style>
  :global(body.cookie-banner-open) {
    overflow: hidden;
  }

  .cookie-banner {
    position: fixed;
    inset: 0;
    z-index: 1000;
    display: flex;
    align-items: flex-end;
    justify-content: center;
    padding: 1.25rem;
  }

  .cookie-banner[aria-hidden='true'] {
    display: none;
  }

  .cookie-banner__backdrop {
    position: absolute;
    inset: 0;
    background: rgba(16, 16, 16, 0.45);
  }

  .cookie-banner__inner {
    position: relative;
    width: min(100%, 980px);
    background: #fff;
    border-radius: 14px;
    box-shadow: 0 24px 60px rgba(16, 16, 16, 0.22);
    border: 1px solid rgba(16, 16, 16, 0.08);
    padding: 1.25rem 1.4rem;
  }

  .cookie-banner__eyebrow {
    margin: 0 0 0.45rem;
    color: #EBA541;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .cookie-banner__title {
    margin: 0 0 0.55rem;
    color: #101010;
    font-family: var(--font-heading);
    font-size: clamp(1.2rem, 2vw, 1.65rem);
    line-height: 1.1;
  }

  .cookie-banner__text {
    margin: 0;
    font-size: 0.95rem;
    color: #4d4d55;
    line-height: 1.7;
  }

  .cookie-banner__note {
    margin: 0.8rem 0 0;
    color: #5f5f68;
    font-size: 0.84rem;
    line-height: 1.6;
    background: #f7f4ee;
    border: 1px solid rgba(235, 165, 65, 0.22);
    border-radius: 12px;
    padding: 0.75rem 0.9rem;
  }

  .cookie-banner__link {
    margin-left: 0.35rem;
    color: #EBA541;
    font-weight: 600;
    white-space: nowrap;
  }

  .cookie-banner__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 1rem;
  }

  .cookie-banner__actions--settings {
    justify-content: flex-start;
  }

  .cookie-btn {
    appearance: none;
    border-radius: 999px;
    cursor: pointer;
    font: inherit;
    font-weight: 600;
    min-height: 44px;
    padding: 0.72rem 1.15rem;
    box-shadow: 0 1px 0 rgba(16, 16, 16, 0.04);
    transition: transform 0.15s ease, background-color 0.15s ease, border-color 0.15s ease, color 0.15s ease;
  }

  .cookie-btn:hover {
    transform: translateY(-1px);
  }

  .cookie-btn--primary {
    background: #EBA541;
    border: 1px solid #EBA541;
    color: #fff;
  }

  .cookie-btn--primary:hover {
    background: #d4922e;
    border-color: #d4922e;
  }

  .cookie-btn--outline {
    background: #fff;
    border: 1px solid #101010;
    color: #101010;
  }

  .cookie-btn--ghost {
    background: #fff;
    border: 1px solid rgba(16, 16, 16, 0.12);
    color: #101010;
  }

  .cookie-btn--outline:hover,
  .cookie-btn--ghost:hover {
    background: rgba(16, 16, 16, 0.04);
  }

  .cookie-options {
    display: grid;
    gap: 0.85rem;
    margin-top: 1rem;
  }

  .cookie-option {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    border: 1px solid rgba(16, 16, 16, 0.08);
    border-radius: 12px;
    padding: 1rem;
    background: #f9fafd;
  }

  .cookie-option__copy {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .cookie-option__title {
    color: #101010;
    font-family: var(--font-heading);
    font-size: 1rem;
    font-weight: 700;
  }

  .cookie-option__description {
    color: #5f5f68;
    font-size: 0.88rem;
    line-height: 1.6;
  }

  .cookie-option input[type='checkbox'] {
    accent-color: #EBA541;
    width: 1.05rem;
    height: 1.05rem;
    margin-top: 0.1rem;
    flex-shrink: 0;
  }

  .cookie-option input[type='checkbox']:disabled {
    opacity: 1;
  }

  @media (max-width: 768px) {
    .cookie-banner {
      padding: 0.85rem;
    }

    .cookie-banner__inner {
      padding: 1rem;
      border-radius: 16px;
    }

    .cookie-banner__actions {
      flex-direction: column;
    }

    .cookie-btn {
      width: 100%;
    }

    .cookie-option {
      padding: 0.85rem 0.9rem;
    }
  }
</style>
