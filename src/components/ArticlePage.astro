---
import Layout from '../layouts/Layout.astro';
import RatingBox from './RatingBox.astro';

interface Props {
  title:       string;
  description?: string;
  heroImage?:  string;
  date:        Date;
  author?:     string;
  Content:     any;
  related:     { id: string; data: { title: string; heroImage?: string; description?: string } }[];
  relatedLabel: string;
  relatedBase:  string;
  collection:   'reviews' | 'guides' | 'alternatives' | 'comparisons' | 'pages';
  hideHeaderDescription?: boolean;
  hideMeta?: boolean;
  ratingTotal?: number;
  price?: number;
  priceCurrency?: string;
}

const { title, description, heroImage, date, author, Content, related, relatedLabel, relatedBase, collection,
        hideHeaderDescription = false, hideMeta = false, ratingTotal, price, priceCurrency } = Astro.props;

const hasRating = ratingTotal !== undefined;

// Extract watch name (strip " Review", " In-Depth Review" etc. from title)
const watchName = title.replace(/\s+(in-depth\s+)?review$/i, '').trim();

const SITE = 'https://www.thewatchresource.com';
const canonicalURL = new URL(Astro.url.pathname, SITE).href;

const COLLECTION_CRUMB: Record<string, { name: string; url: string }> = {
  reviews:      { name: 'Reviews',      url: `${SITE}/reviews/in-depth-watch-reviews/` },
  guides:       { name: 'Guides',       url: `${SITE}/` },
  alternatives: { name: 'Alternatives', url: `${SITE}/alternatives/` },
  comparisons:  { name: 'Comparisons',  url: `${SITE}/` },
  pages:        { name: 'Articles',     url: `${SITE}/` },
};

const crumb = COLLECTION_CRUMB[collection];

const graph: object[] = [
  {
    '@type': 'Article',
    headline: title,
    ...(description && { description }),
    ...(heroImage && { image: heroImage }),
    datePublished: date.toISOString(),
    dateModified:  date.toISOString(),
    url: canonicalURL,
    author: {
      '@type': 'Person',
      name: author || 'Maté D',
      url: SITE,
    },
    publisher: {
      '@type': 'Organization',
      name: 'The Watch Resource',
      logo: {
        '@type': 'ImageObject',
        url: 'https://imagedelivery.net/X-EqW8t9MkEGniKrzeQMdA/ef4c2bd0-2f8e-4c68-ef4c-9ca8dc537400/public',
      },
    },
  },
  {
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: `${SITE}/` },
      { '@type': 'ListItem', position: 2, name: crumb.name, item: crumb.url },
      { '@type': 'ListItem', position: 3, name: title, item: canonicalURL },
    ],
  },
];

if (hasRating && ratingTotal !== undefined) {
  graph.push({
    '@type': 'Product',
    name: watchName,
    ...(heroImage && { image: heroImage }),
    ...(description && { description }),
    aggregateRating: {
      '@type': 'AggregateRating',
      ratingValue: ratingTotal.toFixed(1),
      reviewCount: '1',
      bestRating: '5',
      worstRating: '1',
    },
    ...(price !== undefined && {
      offers: {
        '@type': 'Offer',
        price: price.toFixed(2),
        priceCurrency: priceCurrency ?? 'USD',
        availability: 'https://schema.org/InStock',
      },
    }),
  });
}

const schema = JSON.stringify({ '@context': 'https://schema.org', '@graph': graph });
---

<Layout title={`${title} | The Watch Resource`} description={description} image={heroImage} schema={schema}>
  {heroImage && (
    <img class="hero-image" src={heroImage} alt={title} />
  )}

  <main>
    <article>

      <div class="article-header">
        <h1>{title}</h1>
        {description && !hideHeaderDescription && <p class="description">{description}</p>}
        {!hideMeta && (
          <div class="meta">
            <time datetime={date.toISOString()}>
              {date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
            </time>
            {author && <span>&nbsp;&middot;&nbsp;{author}</span>}
          </div>
        )}
      </div>

      <div class="prose">
        <Content components={{ RatingBox }} />
      </div>

      {related.length > 0 && (
        <div class="related">
          <h3>{relatedLabel}</h3>
          <div class="related-grid">
            {related.map(a => (
              <a href={`${relatedBase}${a.id}/`} class="related-card">
                {a.data.heroImage
                  ? <img src={a.data.heroImage} alt={a.data.title} width="300" height="200" loading="lazy" decoding="async" />
                  : <div class="related-card__placeholder"></div>
                }
                <span class="related-card__title">{a.data.title}</span>
              </a>
            ))}
          </div>
        </div>
      )}

      <div class="author-box">
        <p class="author-label">Written by</p>
        <div class="author-inner">
          <img
            class="author-photo"
            src="https://imagedelivery.net/X-EqW8t9MkEGniKrzeQMdA/24ce8c4b-b692-46f0-abeb-4f6abac16900/public"
            alt="Maté D"
            width="120"
            height="120"
            loading="lazy"
            decoding="async"
          />
          <div class="author-content">
            <p class="author-name">Maté D</p>
            <p class="author-bio">Maté is the founder and chief content creator of The Watch Resource. Since 2021, he has been dedicated to sharing his expert insights and highlighting his favorite brands and timepieces. Driven by a decade-long interest in horology, this watch blog is the result of Maté's deep knowledge and passion.</p>
          </div>
        </div>
      </div>

    </article>
  </main>
</Layout>

<style>
  main {
    max-width: 740px;
    margin: 0 auto;
    padding: 2rem 1.5rem 4rem;
  }

  .hero-image {
    width: 100%;
    max-height: 350px;
    object-fit: cover;
    display: block;
  }

  .article-header {
    margin-bottom: 2.5rem;
  }

  h1 {
    font-size: 2rem;
    line-height: 1.25;
    margin: 0 0 0.75rem;
  }

  .description {
    font-size: 1.125rem;
    color: #6b7280;
    margin: 0 0 1rem;
    line-height: 1.6;
  }

  .meta {
    font-size: 0.875rem;
    color: #9ca3af;
  }

  /* ── Prose ── */
  .prose :global(h2),
  .prose :global(h3),
  .prose :global(h4) {
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    line-height: 1.3;
  }

  .prose :global(p) {
    line-height: 1.75;
    margin-bottom: 1.25rem;
    color: #374151;
  }

  .prose :global(a) {
    color: inherit;
    text-decoration: underline;
  }

  .prose :global(ul),
  .prose :global(ol) {
    padding-left: 1.5rem;
    margin-bottom: 1.25rem;
  }

  .prose :global(li) {
    line-height: 1.75;
    margin-bottom: 0.25rem;
    color: #374151;
  }

  .prose :global(img) {
    max-width: 100%;
    border-radius: 6px;
    display: block;
    margin: 1.5rem auto;
  }

  /* ── Watch card (generated by rehype-watch-cards plugin) ── */
  .prose :global(.watch-card-md) {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    border: 1px solid #e5e7eb;
    border-radius: 6px;
    padding: 1.25rem;
    margin: 1.5rem 0;
    background: #fff;
    align-items: start;
  }

  .prose :global(.watch-card-md__img) {
    display: flex;
    align-items: center;
    justify-content: center;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    text-decoration: none;
  }

  .prose :global(.watch-card-md__img img) {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
    margin: 0;
    border-radius: 0;
    border: none;
  }

  .prose :global(.watch-card-md__body) {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .prose :global(.watch-card-md__body ul) {
    margin: 0;
    padding-left: 1.25rem;
    font-size: 14px;
    color: #7a7a7a;
    line-height: 1.7;
  }

  .prose :global(.watch-card-md__body li) {
    margin-bottom: 0.15rem;
  }

  .prose :global(.watch-card-md__btn) {
    display: block;
    text-align: center;
    background: #d19731;
    color: #fff !important;
    text-decoration: none !important;
    font-weight: 600;
    font-size: 0.95rem;
    padding: 0.65rem 1.25rem;
    border-radius: 4px;
    transition: background 0.15s;
  }

  .prose :global(.watch-card-md__btn:hover) {
    background: #b8831a;
    opacity: 1;
  }

  @media (max-width: 580px) {
    .prose :global(.watch-card-md) {
      grid-template-columns: 1fr;
    }
  }

  /* ── Rating box ── */
  .rating-box {
    margin-top: 3rem;
    padding: 1.75rem;
    border: 1px solid #e5e7eb;
    border-radius: 8px;
    background: #fff;
    text-align: center;
  }

  .rating-title {
    font-size: 1.3rem;
    margin: 0 0 0.75rem;
  }

  .rating-total {
    font-size: 0.95rem;
    color: #6b7280;
    margin: 0 0 0.75rem;
  }

  .rating-total strong {
    color: #101010;
    font-size: 1.1rem;
  }

  .rating-stars-total {
    display: flex;
    justify-content: center;
    gap: 4px;
    margin-bottom: 1.75rem;
  }

  .rating-categories {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
    border-top: 1px solid #e5e7eb;
    padding-top: 1.25rem;
  }

  .rating-cat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.4rem;
  }

  .rating-cat__label {
    font-size: 0.82rem;
    font-weight: 600;
    color: #374151;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .rating-cat__stars {
    display: flex;
    gap: 2px;
  }

  @media (max-width: 480px) {
    .rating-categories { grid-template-columns: repeat(2, 1fr); }
  }

  /* ── Related ── */
  .related {
    margin-top: 3rem;
    padding-top: 1.75rem;
    border-top: 1px solid #e5e7eb;
  }

  .related h3 {
    font-size: 1rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin: 0 0 1.25rem;
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
  }

  .related-card {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    text-decoration: none;
    border: 1px solid #e5e7eb;
    border-radius: 6px;
    overflow: hidden;
    background: #fff;
    transition: border-color 0.15s;
  }

  .related-card:hover {
    border-color: #EBA541;
    opacity: 1;
  }

  .related-card img,
  .related-card__placeholder {
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    display: block;
  }

  .related-card__placeholder {
    background: #f3f4f6;
  }

  .related-card__title {
    font-size: 0.8rem;
    font-weight: 600;
    color: #101010;
    line-height: 1.35;
    padding: 0 0.75rem 0.75rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  @media (max-width: 700px) {
    .related-grid { grid-template-columns: repeat(2, 1fr); }
  }

  /* ── Author box ── */
  .author-box {
    margin-top: 3rem;
    padding: 1.75rem 0;
    border-top: 1px solid #e5e7eb;
    border-bottom: 1px solid #e5e7eb;
  }

  .author-label {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #9ca3af;
    margin: 0 0 1rem;
  }

  .author-inner {
    display: flex;
    align-items: flex-start;
    gap: 1.25rem;
  }

  .author-photo {
    width: 90px;
    height: 90px;
    object-fit: cover;
    border-radius: 4px;
    flex-shrink: 0;
  }

  .author-name {
    font-family: var(--font-heading);
    font-size: 1.1rem;
    font-weight: 700;
    color: #101010;
    margin: 0 0 0.5rem;
  }

  .author-bio {
    font-size: 0.9rem;
    color: #6b7280;
    line-height: 1.7;
    margin: 0;
  }
</style>
