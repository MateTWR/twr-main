---
import Layout from '../layouts/Layout.astro';

interface Props {
  title:       string;
  description?: string;
  heroImage?:  string;
  date:        Date;
  author?:     string;
  Content:     any;
  related:     { id: string; data: { title: string } }[];
  relatedLabel: string;
}

const { title, description, heroImage, date, author, Content, related, relatedLabel } = Astro.props;
---

<Layout title={`${title} | The Watch Resource`} description={description} image={heroImage}>
  {heroImage && (
    <img class="hero-image" src={heroImage} alt={title} />
  )}

  <main>
    <article>

      <div class="article-header">
        <h1>{title}</h1>
        {description && <p class="description">{description}</p>}
        <div class="meta">
          <time datetime={date.toISOString()}>
            {date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
          </time>
          {author && <span>&nbsp;&middot;&nbsp;{author}</span>}
        </div>
      </div>

      <div class="prose">
        <Content />
      </div>

      {related.length > 0 && (
        <div class="related">
          <h3>{relatedLabel}</h3>
          <ul>
            {related.map(a => (
              <li><a href={`/${a.id}/`}>{a.data.title}</a></li>
            ))}
          </ul>
        </div>
      )}

      <div class="author-box">
        <p class="author-label">Written by</p>
        <div class="author-inner">
          <img
            class="author-photo"
            src="https://www.thewatchresource.com/wp-content/uploads/2025/03/A416E09C-8EB9-454A-9A03-18A520AED450_1_105_c-e1743132097488.jpeg"
            alt="Maté D"
            width="120"
            height="120"
            loading="lazy"
            decoding="async"
          />
          <div class="author-content">
            <p class="author-name">Maté D</p>
            <p class="author-bio">Maté is the founder and chief content creator of The Watch Resource. Since 2021, he has been dedicated to sharing his expert insights and highlighting his favorite brands and timepieces. Driven by a decade-long interest in horology, this watch blog is the result of Maté's deep knowledge and passion.</p>
          </div>
        </div>
      </div>

    </article>
  </main>
</Layout>

<style>
  main {
    max-width: 740px;
    margin: 0 auto;
    padding: 2rem 1.5rem 4rem;
  }

  .hero-image {
    width: 100%;
    max-height: 350px;
    object-fit: cover;
    display: block;
  }

  .article-header {
    margin-bottom: 2.5rem;
  }

  h1 {
    font-size: 2rem;
    line-height: 1.25;
    margin: 0 0 0.75rem;
  }

  .description {
    font-size: 1.125rem;
    color: #6b7280;
    margin: 0 0 1rem;
    line-height: 1.6;
  }

  .meta {
    font-size: 0.875rem;
    color: #9ca3af;
  }

  /* ── Prose ── */
  .prose :global(h2),
  .prose :global(h3),
  .prose :global(h4) {
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    line-height: 1.3;
  }

  .prose :global(p) {
    line-height: 1.75;
    margin-bottom: 1.25rem;
    color: #374151;
  }

  .prose :global(a) {
    color: inherit;
    text-decoration: underline;
  }

  .prose :global(ul),
  .prose :global(ol) {
    padding-left: 1.5rem;
    margin-bottom: 1.25rem;
  }

  .prose :global(li) {
    line-height: 1.75;
    margin-bottom: 0.25rem;
    color: #374151;
  }

  .prose :global(img) {
    max-width: 100%;
    border-radius: 6px;
    display: block;
    margin: 1.5rem auto;
  }

  /* ── Watch card (generated by rehype-watch-cards plugin) ── */
  .prose :global(.watch-card-md) {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    border: 1px solid #e5e7eb;
    border-radius: 6px;
    padding: 1.25rem;
    margin: 1.5rem 0;
    background: #fff;
    align-items: start;
  }

  .prose :global(.watch-card-md__img) {
    display: flex;
    align-items: center;
    justify-content: center;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    text-decoration: none;
  }

  .prose :global(.watch-card-md__img img) {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
    margin: 0;
    border-radius: 0;
    border: none;
  }

  .prose :global(.watch-card-md__body) {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .prose :global(.watch-card-md__body ul) {
    margin: 0;
    padding-left: 1.25rem;
    font-size: 14px;
    color: #7a7a7a;
    line-height: 1.7;
  }

  .prose :global(.watch-card-md__body li) {
    margin-bottom: 0.15rem;
  }

  .prose :global(.watch-card-md__btn) {
    display: block;
    text-align: center;
    background: #d19731;
    color: #fff !important;
    text-decoration: none !important;
    font-weight: 600;
    font-size: 0.95rem;
    padding: 0.65rem 1.25rem;
    border-radius: 4px;
    transition: background 0.15s;
  }

  .prose :global(.watch-card-md__btn:hover) {
    background: #b8831a;
    opacity: 1;
  }

  @media (max-width: 580px) {
    .prose :global(.watch-card-md) {
      grid-template-columns: 1fr;
    }
  }

  /* ── Related ── */
  .related {
    margin-top: 3rem;
    padding-top: 1.75rem;
    border-top: 1px solid #e5e7eb;
  }

  .related h3 {
    font-size: 1rem;
    font-weight: 700;
    margin: 0 0 0.75rem;
  }

  .related ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .related a {
    color: #EBA541;
    text-decoration: none;
    font-size: 0.95rem;
  }

  .related a:hover {
    text-decoration: underline;
  }

  /* ── Author box ── */
  .author-box {
    margin-top: 3rem;
    padding: 1.75rem 0;
    border-top: 1px solid #e5e7eb;
    border-bottom: 1px solid #e5e7eb;
  }

  .author-label {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #9ca3af;
    margin: 0 0 1rem;
  }

  .author-inner {
    display: flex;
    align-items: flex-start;
    gap: 1.25rem;
  }

  .author-photo {
    width: 90px;
    height: 90px;
    object-fit: cover;
    border-radius: 4px;
    flex-shrink: 0;
  }

  .author-name {
    font-family: var(--font-heading);
    font-size: 1.1rem;
    font-weight: 700;
    color: #101010;
    margin: 0 0 0.5rem;
  }

  .author-bio {
    font-size: 0.9rem;
    color: #6b7280;
    line-height: 1.7;
    margin: 0;
  }
</style>
