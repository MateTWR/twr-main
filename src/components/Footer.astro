---
const ALT = '/alternatives';
const year = new Date().getFullYear();

const caret = `<svg aria-hidden="true" viewBox="0 0 192 512" xmlns="http://www.w3.org/2000/svg" width="8" height="8"><path d="M0 384.662V127.338c0-17.818 21.543-26.741 34.142-14.142l128.662 128.662c7.81 7.81 7.81 20.474 0 28.284L34.142 398.804C21.543 411.404 0 402.48 0 384.662z"/></svg>`;
---

<script is:inline>
  // Newsletter form — submits to HubSpot Forms API
  window.addEventListener('DOMContentLoaded', function () {
  document.getElementById('newsletter-form')?.addEventListener('submit', function (e) {
    e.preventDefault();
    var email = document.getElementById('newsletter-email').value.trim();
    var msg = document.getElementById('newsletter-msg');
    var btn = this.querySelector('button[type=submit]');

    if (!email) return;

    btn.disabled = true;
    btn.textContent = 'Sending…';

    fetch('https://api.hsforms.com/submissions/v3/integration/submit/39792346/9a63b58c-5278-4ffd-be42-eb179aeb8fd7', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        fields: [{ name: 'email', value: email }],
        context: { pageUri: window.location.href, pageName: document.title }
      })
    })
    .then(function (res) {
      if (res.ok) {
        msg.textContent = 'You\'re signed up — thank you!';
        msg.className = 'newsletter-msg newsletter-msg--success';
        document.getElementById('newsletter-form').reset();
      } else {
        throw new Error('Error');
      }
    })
    .catch(function () {
      msg.textContent = 'Something went wrong. Please try again.';
      msg.className = 'newsletter-msg newsletter-msg--error';
    })
    .finally(function () {
      btn.disabled = false;
      btn.textContent = 'Sign Up';
    });
  });

  document.getElementById('footer-opt-out')?.addEventListener('click', function () {
    localStorage.setItem('twr_cookie_consent', 'declined');
    window.dataLayer = window.dataLayer || [];
    function gtag() { dataLayer.push(arguments); }
    gtag('consent', 'update', {
      analytics_storage: 'denied',
      ad_storage: 'denied',
      ad_user_data: 'denied',
      ad_personalization: 'denied'
    });
    alert('Your preference has been saved. Analytics tracking has been disabled.');
  });
  }); // end DOMContentLoaded
</script>

<footer class="site-footer">
  <div class="footer-inner">

    <!-- Col 1: Logo + about + copyright -->
    <div class="footer-col footer-col--brand">
      <a href="/" class="footer-logo">
        <img
          src="https://imagedelivery.net/X-EqW8t9MkEGniKrzeQMdA/ef4c2bd0-2f8e-4c68-ef4c-9ca8dc537400/public"
          alt="The Watch Resource"
          width="340"
          height="75"
          loading="lazy"
          decoding="async"
        />
      </a>
      <p class="footer-about">
        The Watch Resource is an independent watch review site founded in 2021, where a team of watch
        enthusiasts works tirelessly to create educational buyer's guides and insightful reviews.
      </p>
      <p class="footer-copy">&copy; {year} All rights reserved</p>
      <p class="footer-copy"><button id="footer-opt-out" class="footer-optout">Do Not Sell or Share My Personal Information</button></p>
    </div>

    <!-- Col 2: Navigation -->
    <div class="footer-col">
      <h4 class="footer-heading">Navigation</h4>
      <ul class="footer-links">
        <li><a href="/in-depth-watch-reviews/"><Fragment set:html={caret} />Watch Reviews</a></li>
        <li><a href="/brand-reviews/"><Fragment set:html={caret} />Brand Reviews</a></li>
        <li><a href={ALT}><Fragment set:html={caret} />Alternatives</a></li>
        <li><a href="/watch-comparisons/"><Fragment set:html={caret} />Comparisons</a></li>
      </ul>
    </div>

    <!-- Col 3: Newsletter -->
    <div class="footer-col">
      <h4 class="footer-heading">Newsletter</h4>
      <p class="newsletter-headline">Join the Newsletter!</p>
      <p class="newsletter-tagline">Sign up for the newsletter for exclusive content, watch reviews, and buyer's guides.</p>
      <form class="newsletter-form" id="newsletter-form" novalidate>
        <input
          type="email"
          name="email"
          id="newsletter-email"
          placeholder="Your email address"
          required
          autocomplete="email"
          class="newsletter-input"
        />
        <button type="submit" class="newsletter-btn">Sign Up</button>
        <p class="newsletter-msg" id="newsletter-msg" aria-live="polite"></p>
      </form>
    </div>

  </div>
</footer>

<style>
  .site-footer {
    background-color: #101010;
    color: rgba(255, 255, 255, 0.85);
    margin-top: 4rem;
  }

  .footer-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 3.5rem 1.5rem 2.5rem;
    display: grid;
    grid-template-columns: 1.6fr 1fr 1fr;
    gap: 3rem;
  }

  .footer-logo {
    display: inline-block;
    margin-bottom: 1.25rem;
    text-decoration: none;
  }

  .footer-logo img {
    height: 50px;
    width: auto;
    display: block;
    filter: brightness(0) invert(1);
    opacity: 0.9;
  }

  .footer-about {
    font-size: 0.85rem;
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.75);
    margin: 0 0 1rem;
  }

  .footer-copy {
    font-size: 0.8rem;
    color: rgba(255, 255, 255, 0.35);
    margin: 0;
  }

  .footer-heading {
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #fff;
    margin: 0 0 1.25rem;
  }

  .footer-links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .footer-links a {
    color: rgba(255, 255, 255, 0.8);
    text-decoration: none;
    font-size: 0.875rem;
    display: flex;
    align-items: center;
    gap: 0.45rem;
    transition: color 0.15s;
  }

  .footer-links a:hover {
    color: #EBA541;
    opacity: 1;
  }

  .footer-links svg {
    fill: #EBA541;
    flex-shrink: 0;
  }


  .newsletter-headline {
    font-family: var(--font-heading);
    font-size: 1.1rem;
    font-weight: 700;
    color: #fff;
    margin: 0 0 0.4rem;
  }

  .newsletter-tagline {
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.65);
    line-height: 1.6;
    margin: 0 0 1.1rem;
  }

  .newsletter-form {
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
  }

  .newsletter-input {
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 4px;
    color: #fff;
    font-family: inherit;
    font-size: 0.875rem;
    padding: 0.6rem 0.85rem;
    outline: none;
    transition: border-color 0.15s;
    width: 100%;
    box-sizing: border-box;
  }

  .newsletter-input::placeholder {
    color: rgba(255, 255, 255, 0.35);
  }

  .newsletter-input:focus {
    border-color: #EBA541;
  }

  .newsletter-btn {
    background: #EBA541;
    border: none;
    border-radius: 4px;
    color: #fff;
    cursor: pointer;
    font-family: inherit;
    font-size: 0.875rem;
    font-weight: 600;
    padding: 0.65rem 1.25rem;
    transition: background 0.15s;
    width: 100%;
  }

  .newsletter-btn:hover {
    background: #d4922e;
  }

  .newsletter-btn:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  .newsletter-msg {
    font-size: 0.8rem;
    margin: 0;
    min-height: 1.2em;
  }

  .newsletter-msg--success {
    color: #86efac;
  }

  .newsletter-msg--error {
    color: #f87171;
  }

  .footer-optout {
    background: none;
    border: none;
    color: rgba(255, 255, 255, 0.35);
    cursor: pointer;
    font-family: inherit;
    font-size: 0.8rem;
    padding: 0;
    text-decoration: underline;
  }

  .footer-optout:hover {
    color: rgba(255, 255, 255, 0.6);
  }

  @media (max-width: 768px) {
    .footer-inner {
      grid-template-columns: 1fr;
      gap: 2.5rem;
      padding: 2.5rem 1.5rem 2rem;
    }
  }
</style>
