<script>
  // Mobile toggle
  const toggle = document.querySelector('.navbar-toggle') as HTMLButtonElement;
  const nav = document.querySelector('#main-nav') as HTMLElement;
  toggle?.addEventListener('click', () => {
    const expanded = toggle.getAttribute('aria-expanded') === 'true';
    toggle.setAttribute('aria-expanded', String(!expanded));
    nav.classList.toggle('open');
  });

  // Scroll transparency
  const header = document.querySelector('.site-header') as HTMLElement;
  window.addEventListener('scroll', () => {
    header.classList.toggle('scrolled', window.scrollY > 40);
  }, { passive: true });
</script>

<style>
  /* ── Header shell ── */
  .site-header {
    background-color: #fff;
    color: #101010;
    position: sticky;
    top: 0;
    z-index: 100;
    width: 100%;
    border-bottom: 1px solid rgba(0,0,0,0.08);
    transition: background-color 0.2s, backdrop-filter 0.2s;
  }

  .site-header.scrolled {
    background-color: rgba(255,255,255,0.88);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
  }

  .navbar {
    width: 100%;
  }

  .inner-wrap {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    min-height: 70px;
    flex-wrap: wrap;
  }

  /* ── Logo ── */
  .navbar-brand a {
    display: flex;
    align-items: center;
    text-decoration: none;
  }

  .navbar-brand img {
    height: 40px;
    width: auto;
    display: block;
  }

  /* ── Search ── */
  .header-search {
    display: flex;
    align-items: center;
  }

  .header-search form {
    display: flex;
    align-items: center;
    background: rgba(0,0,0,0.06);
    border-radius: 4px;
    overflow: hidden;
  }

  .header-search input[type="search"] {
    background: transparent;
    border: none;
    color: #101010;
    padding: 0.4rem 0.6rem;
    font-size: 0.85rem;
    width: 160px;
    outline: none;
    font-family: inherit;
  }

  .header-search input[type="search"]::placeholder {
    color: rgba(0,0,0,0.4);
  }

  .header-search button {
    background: transparent;
    border: none;
    color: rgba(0,0,0,0.5);
    padding: 0.4rem 0.6rem;
    cursor: pointer;
    display: flex;
    align-items: center;
  }

  .header-search button:hover {
    color: #101010;
  }

  /* ── Mobile toggle ── */
  .navbar-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: transparent;
    border: 1px solid rgba(0,0,0,0.2);
    border-radius: 4px;
    padding: 0.5rem 0.6rem;
    cursor: pointer;
  }

  .icon-bar {
    display: block;
    width: 22px;
    height: 2px;
    background: #101010;
    border-radius: 1px;
  }

  /* ── Nav menu ── */
  .navbar-collapse {
    display: flex;
    align-items: center;
  }

  .nav-menu {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    align-items: center;
    gap: 0;
  }

  .nav-menu > li > a {
    display: block;
    color: #EBA541;
    text-decoration: none;
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    padding: 1.4rem 0.85rem;
    white-space: nowrap;
    transition: color 0.15s;
    position: relative;
  }

  .nav-menu > li > a:hover {
    color: #d4922e;
  }

  .nav-menu > li.active > a {
    color: #101010;
  }

  /* Active underline */
  .nav-menu > li.active > a::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0.85rem;
    right: 0.85rem;
    height: 2px;
    background: #101010;
  }

  /* ── Dropdown ── */
  .has-dropdown {
    position: relative;
  }

  .dropdown {
    list-style: none;
    margin: 0;
    padding: 0.5rem 0;
    position: absolute;
    top: 100%;
    left: 0;
    background: #fff;
    min-width: 240px;
    box-shadow: 0 4px 20px rgba(0,0,0,0.12);
    border-top: 2px solid #EBA541;
    opacity: 0;
    visibility: hidden;
    transform: translateY(6px);
    transition: opacity 0.18s, transform 0.18s, visibility 0.18s;
    z-index: 200;
  }

  /* Second-level dropdown */
  .dropdown .has-dropdown .dropdown {
    top: 0;
    left: 100%;
    border-top: none;
    border-left: 2px solid #EBA541;
  }

  .has-dropdown:hover > .dropdown {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .dropdown li a {
    display: block;
    color: #444;
    text-decoration: none;
    font-size: 0.82rem;
    padding: 0.5rem 1.1rem;
    transition: color 0.12s, background 0.12s;
    white-space: nowrap;
  }

  .dropdown li a:hover {
    color: #101010;
    background: rgba(235, 165, 65, 0.1);
  }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .navbar-toggle {
      display: flex;
    }

    .header-search {
      display: none;
    }

    .navbar-collapse {
      display: none;
      width: 100%;
      order: 10;
      padding-bottom: 1rem;
    }

    .navbar-collapse.open {
      display: flex;
    }

    .nav-menu {
      flex-direction: column;
      align-items: flex-start;
      width: 100%;
    }

    .nav-menu > li {
      width: 100%;
    }

    .nav-menu > li > a {
      padding: 0.7rem 0;
      border-bottom: 1px solid rgba(0,0,0,0.08);
      width: 100%;
    }

    .nav-menu > li.active > a::after {
      display: none;
    }

    .dropdown {
      position: static;
      opacity: 1;
      visibility: visible;
      transform: none;
      box-shadow: none;
      border-top: none;
      border-left: 2px solid #EBA541;
      margin-left: 1rem;
      background: transparent;
    }

    .dropdown .has-dropdown .dropdown {
      border-left: 2px solid rgba(235,165,65,0.4);
    }

    .dropdown li a {
      padding: 0.4rem 0.8rem;
    }
  }
</style>
