---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  image?: string;
  schema?: string;
}

const { title, description = 'Independent watch reviews, buyer\'s guides, and comparisons.', image, schema } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en-US">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content="article" />
    <meta property="og:site_name" content="The Watch Resource" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    {image && <meta property="og:image" content={image} />}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {image && <meta name="twitter:image" content={image} />}

    <!-- Google Fonts — Roboto (body) + DM Sans (headings/nav) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Roboto:ital,wght@0,300;0,400;0,500;0,700;1,300;1,400&family=DM+Sans:opsz,wght@9..40,400;9..40,500;9..40,600;9..40,700&display=swap"
      rel="stylesheet"
    />
    <!-- Google Analytics 4 -->
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-TF4DXGH4V0"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-TF4DXGH4V0');
    </script>

    <!-- HubSpot -->
    <script is:inline type="text/javascript" id="hs-script-loader" async defer src="//js.hs-scripts.com/39792346.js"></script>

    <!-- Structured data -->
    {schema && <script type="application/ld+json" set:html={schema} />}
  </head>
  <body>
    <Header />

    <slot />

    <Footer />
  </body>
</html>

<style is:global>
  /* ── Design tokens ── */
  :root {
    --color-primary:    #0bb4aa;
    --color-secondary:  #101010;
    --color-tertiary:   #6C6C77;
    --color-background: #f9fafd;
    --color-surface:    #ffffff;
    --color-lightgrey:  #D9D9D9;

    --font-body:    "Roboto", -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    --font-heading: "DM Sans", -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;

    --line-height-body:    1.75;
    --line-height-heading: 1.1;

    --content-width: 1200px;
  }

  *, *::before, *::after {
    box-sizing: border-box;
  }

  html {
    font-size: 16px;
    -webkit-text-size-adjust: 100%;
  }

  body {
    margin: 0;
    padding: 0;
    background-color: var(--color-background);
    color: #7a7a7a;
    font-family: var(--font-body);
    font-size: 14px;
    line-height: 1.75;
  }

  h1, h2, h3, h4, h5, h6 {
    font-family: var(--font-heading);
    color: #101010;
    line-height: 1.1;
  }

  a {
    color: var(--color-primary);
    text-decoration: underline;
  }

  a:hover {
    opacity: 0.8;
  }

  img {
    max-width: 100%;
    height: auto;
  }
</style>
