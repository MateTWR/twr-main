---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CookieBanner from '../components/CookieBanner.astro';

interface Props {
  title: string;
  description?: string;
  image?: string;
  schema?: string;
}

const { title, description = 'Independent watch reviews, buyer\'s guides, and comparisons.', image, schema } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en-US">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content="article" />
    <meta property="og:site_name" content="The Watch Resource" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    {image && <meta property="og:image" content={image} />}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {image && <meta name="twitter:image" content={image} />}

    <!-- Google Fonts — Roboto (body) + DM Sans (headings/nav) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Roboto:ital,wght@0,300;0,400;0,500;0,700;1,300;1,400&family=DM+Sans:opsz,wght@9..40,400;9..40,500;9..40,600;9..40,700&display=swap"
      rel="stylesheet"
    />

    <!-- GTM consent bootstrap -->
    <script is:inline>
      (function () {
        var STORAGE_KEY = 'twr_cookie_consent';
        var GTM_ID = 'GTM-T859CMW';

        window.dataLayer = window.dataLayer || [];
        function gtag(){ window.dataLayer.push(arguments); }
        window.gtag = window.gtag || gtag;

        function readStoredConsent() {
          try {
            var stored = localStorage.getItem(STORAGE_KEY);
            if (!stored) return null;

            var parsed = JSON.parse(stored);
            if (parsed && typeof parsed === 'object') {
              return Boolean(parsed.analytics);
            }

            if (stored === 'accepted') return true;
            if (stored === 'declined') return false;
          } catch (_) {}

          return null;
        }

        var analyticsGranted = readStoredConsent() === true;

        gtag('consent', 'default', {
          analytics_storage: analyticsGranted ? 'granted' : 'denied',
          ad_storage: 'denied',
          ad_user_data: 'denied',
          ad_personalization: 'denied',
          functionality_storage: 'granted',
          personalization_storage: 'denied',
          security_storage: 'granted',
          wait_for_update: 500
        });

        window.twrLoadGTM = window.twrLoadGTM || function () {
          if (window.__twrGtmLoaded) return;
          window.__twrGtmLoaded = true;

          window.dataLayer.push({
            'gtm.start': new Date().getTime(),
            event: 'gtm.js'
          });

          var script = document.createElement('script');
          script.async = true;
          script.src = 'https://www.googletagmanager.com/gtm.js?id=' + encodeURIComponent(GTM_ID);
          document.head.appendChild(script);
        };

        // Advanced consent mode: load GTM on every page with consent defaults already set.
        // When analytics consent is denied, Google tags may send cookieless pings only.
        window.twrLoadGTM();
      })();
    </script>

    <!-- HubSpot -->
    <script is:inline type="text/javascript" id="hs-script-loader" async defer src="//js.hs-scripts.com/39792346.js"></script>

    <!-- Structured data -->
    {schema && <script type="application/ld+json" set:html={schema} />}
  </head>
  <body>
    <Header />

    <slot />

    <Footer />
    <CookieBanner />
  </body>
</html>

<style is:global>
  /* ── Design tokens ── */
  :root {
    --color-primary:    #0bb4aa;
    --color-secondary:  #101010;
    --color-tertiary:   #6C6C77;
    --color-background: #f9fafd;
    --color-surface:    #ffffff;
    --color-lightgrey:  #D9D9D9;

    --font-body:    "Roboto", -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    --font-heading: "DM Sans", -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;

    --line-height-body:    1.75;
    --line-height-heading: 1.1;

    --content-width: 1200px;
  }

  *, *::before, *::after {
    box-sizing: border-box;
  }

  html {
    font-size: 16px;
    -webkit-text-size-adjust: 100%;
  }

  body {
    margin: 0;
    padding: 0;
    background-color: var(--color-background);
    color: #7a7a7a;
    font-family: var(--font-body);
    font-size: 14px;
    line-height: 1.75;
  }

  h1, h2, h3, h4, h5, h6 {
    font-family: var(--font-heading);
    color: #101010;
    line-height: 1.1;
  }

  a {
    color: var(--color-primary);
    text-decoration: underline;
  }

  a:hover {
    opacity: 0.8;
  }

  img {
    max-width: 100%;
    height: auto;
  }
</style>
