---
import { getCollection, render } from 'astro:content';
import ArticlePage from '../../components/ArticlePage.astro';

export async function getStaticPaths() {
  const INDEX_SLUGS = new Set(['in-depth-watch-reviews', 'brand-reviews']);
  const entries = await getCollection('reviews', ({ data, id }) => !data.draft && !INDEX_SLUGS.has(id));
  return entries.map(entry => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const all = await getCollection('reviews', ({ data }) => !data.draft);
const related = all
  .filter(a => a.id !== entry.id)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 8);
---

<ArticlePage
  title={entry.data.title}
  seoTitle={entry.data.seoTitle}
  description={entry.data.description}
  heroImage={entry.data.heroImage}
  date={entry.data.date}
  author={entry.data.author}
  Content={Content}
  related={related}
  relatedLabel="More Watch Reviews"
  relatedBase="/reviews/"
  collection="reviews"
  ratingTotal={entry.data.ratingTotal}
  price={entry.data.price}
  priceCurrency={entry.data.priceCurrency}
/>
