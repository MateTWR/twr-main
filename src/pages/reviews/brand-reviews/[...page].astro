---
import { getCollection } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';

export async function getStaticPaths({ paginate }) {
  const EXCLUDE = new Set(['in-depth-watch-reviews', 'brand-reviews']);
  const all = await getCollection('reviews', ({ data, id }) =>
    !data.draft && !EXCLUDE.has(id) && id.includes('brand')
  );
  const sorted = all.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
  return paginate(sorted, { pageSize: 10 });
}

const { page } = Astro.props;
const title = page.currentPage === 1
  ? 'Watch Brand Reviews — The Watch Resource'
  : `Watch Brand Reviews — Page ${page.currentPage} — The Watch Resource`;
---

<Layout title={title} description="In-depth brand reviews covering watch brand history, collections, and what to buy. From The Watch Resource.">
  <main class="listing-page">
    <header class="listing-header">
      <h1>Watch Brand Reviews</h1>
      <p>Deep dives into watch brands — their history, collections, and best buys.</p>
    </header>

    <div class="listing-grid">
      {page.data.map(review => (
        <article class="card">
          {review.data.heroImage && (
            <a href={`/reviews/${review.id}/`} class="card-image-wrap">
              <img
                src={review.data.heroImage}
                alt={review.data.title}
                width="600"
                height="400"
                loading="lazy"
                decoding="async"
              />
            </a>
          )}
          <div class="card-body">
            <h2><a href={`/reviews/${review.id}/`}>{review.data.title}</a></h2>
            {review.data.description && <p class="card-desc">{review.data.description}</p>}
            <time class="card-date" datetime={review.data.date.toISOString()}>
              {review.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
            </time>
          </div>
        </article>
      ))}
    </div>

    {page.lastPage > 1 && (
      <nav class="pagination" aria-label="Pagination">
        {page.url.prev && <a href={page.url.prev} class="page-btn">&larr; Newer</a>}
        <span class="page-info">Page {page.currentPage} of {page.lastPage}</span>
        {page.url.next && <a href={page.url.next} class="page-btn">Older &rarr;</a>}
      </nav>
    )}
  </main>
</Layout>

<style>
  .listing-page {
    max-width: 1200px;
    margin: 0 auto;
    padding: 3rem 1.5rem 5rem;
  }

  .listing-header {
    text-align: center;
    margin-bottom: 3rem;
    padding-bottom: 1.5rem;
    border-bottom: 2px solid #EBA541;
  }

  .listing-header h1 {
    font-size: 1.75rem;
    margin: 0 0 0.5rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .listing-header p {
    font-size: 0.95rem;
    color: #6b7280;
    margin: 0;
  }

  .listing-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    margin-bottom: 3rem;
  }

  .card {
    background: #fff;
    border: 1px solid #e5e7eb;
    border-radius: 6px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  .card-image-wrap {
    display: block;
    aspect-ratio: 16 / 9;
    overflow: hidden;
  }

  .card-image-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.3s ease;
  }

  .card:hover .card-image-wrap img {
    transform: scale(1.03);
  }

  .card-body {
    padding: 1rem 1.1rem 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    flex: 1;
  }

  .card-body h2 {
    font-size: 0.95rem;
    font-weight: 700;
    margin: 0;
    line-height: 1.35;
  }

  .card-body h2 a {
    color: #101010;
    text-decoration: none;
  }

  .card-body h2 a:hover {
    color: #EBA541;
    opacity: 1;
  }

  .card-desc {
    font-size: 0.85rem;
    color: #6b7280;
    line-height: 1.6;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-date {
    font-size: 0.78rem;
    color: #9ca3af;
    margin-top: auto;
  }

  .pagination {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.5rem;
    padding-top: 2rem;
    border-top: 1px solid #e5e7eb;
  }

  .page-btn {
    display: inline-block;
    background: #EBA541;
    color: #fff;
    text-decoration: none;
    font-size: 0.875rem;
    font-weight: 600;
    padding: 0.55rem 1.25rem;
    border-radius: 4px;
    transition: background 0.15s;
  }

  .page-btn:hover {
    background: #d4922e;
    opacity: 1;
  }

  .page-info {
    font-size: 0.875rem;
    color: #6b7280;
  }

  @media (max-width: 900px) {
    .listing-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 580px) {
    .listing-grid { grid-template-columns: 1fr; }
    .listing-header h1 { font-size: 1.4rem; }
  }
</style>
