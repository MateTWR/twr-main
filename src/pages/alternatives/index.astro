---
import { getCollection, getEntry, render } from 'astro:content';
import ArticlePage from '../../components/ArticlePage.astro';

const entry = await getEntry('alternatives', 'alternatives');

if (!entry || entry.data.draft) {
  return Astro.redirect('/');
}

const { Content } = await render(entry);

const all = await getCollection('alternatives', ({ data, id }) => !data.draft && id !== entry.id);
const related = all
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 8);
---

<ArticlePage
  title={entry.data.title}
  description={entry.data.description}
  heroImage={entry.data.heroImage}
  date={entry.data.date}
  author={entry.data.author}
  Content={Content}
  related={related}
  relatedLabel="More Watch Alternatives"
  relatedBase="/alternatives/"
  collection="alternatives"
  hideHeaderDescription
  hideMeta
/>
