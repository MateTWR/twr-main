---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const pages = await getCollection('pages', ({ data }) => !data.draft);
const page = pages.find(p => p.id === 'watch-comparisons');
if (!page) throw new Error('watch-comparisons page not found');
const { Content } = await render(page);

const comparisons = await getCollection('comparisons', ({ data }) => !data.draft);
comparisons.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const related = pages
  .filter(p => p.id !== 'watch-comparisons')
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 8);
---

<Layout
  title={`${page.data.title} | The Watch Resource`}
  description={page.data.description}
>
  <main>
    <article>

      <div class="article-header">
        <h1>{page.data.title}</h1>
        {page.data.description && <p class="description">{page.data.description}</p>}
      </div>

      <div class="prose">
        <Content />
      </div>

      <!-- Comparison article list -->
      {comparisons.length > 0 && (
        <div class="comparisons-list">
          {comparisons.map(c => (
            <a href={`/comparisons/${c.id}/`} class="comparison-tile">
              {c.data.heroImage
                ? <img src={c.data.heroImage} alt={c.data.title} width="220" height="148" loading="lazy" decoding="async" class="comparison-tile__img" />
                : <div class="comparison-tile__placeholder"></div>
              }
              <div class="comparison-tile__body">
                <h2 class="comparison-tile__title">{c.data.title}</h2>
                {c.data.description && <p class="comparison-tile__desc">{c.data.description}</p>}
                <span class="comparison-tile__cta">Read Comparison →</span>
              </div>
            </a>
          ))}
        </div>
      )}

      <!-- More articles -->
      {related.length > 0 && (
        <div class="related">
          <h3>More Articles</h3>
          <div class="related-grid">
            {related.map(a => (
              <a href={`/pages/${a.id}/`} class="related-card">
                {a.data.heroImage
                  ? <img src={a.data.heroImage} alt={a.data.title} width="300" height="200" loading="lazy" decoding="async" />
                  : <div class="related-card__placeholder"></div>
                }
                <span class="related-card__title">{a.data.title}</span>
              </a>
            ))}
          </div>
        </div>
      )}

    </article>
  </main>
</Layout>

<style>
  main {
    max-width: 740px;
    margin: 0 auto;
    padding: 2rem 1.5rem 4rem;
  }

  .article-header {
    margin-bottom: 2.5rem;
  }

  h1 {
    font-size: 2rem;
    line-height: 1.25;
    margin: 0 0 0.75rem;
  }

  .description {
    font-size: 1.125rem;
    color: #6b7280;
    margin: 0;
    line-height: 1.6;
  }

  .prose :global(p) {
    line-height: 1.75;
    margin-bottom: 1.25rem;
    color: #374151;
  }

  /* ── Comparison tiles ── */
  .comparisons-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-top: 2.5rem;
  }

  .comparison-tile {
    display: flex;
    gap: 1.25rem;
    border: 1px solid #e5e7eb;
    border-radius: 8px;
    overflow: hidden;
    background: #fff;
    text-decoration: none;
    transition: border-color 0.15s, box-shadow 0.15s;
  }

  .comparison-tile:hover {
    border-color: #EBA541;
    box-shadow: 0 2px 12px rgba(235, 165, 65, 0.12);
    opacity: 1;
  }

  .comparison-tile__img,
  .comparison-tile__placeholder {
    width: 220px;
    min-width: 220px;
    height: 148px;
    object-fit: cover;
    display: block;
    flex-shrink: 0;
  }

  .comparison-tile__placeholder {
    background: #f3f4f6;
  }

  .comparison-tile__body {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0.4rem;
    padding: 1rem 1.25rem 1rem 0;
  }

  .comparison-tile__title {
    font-size: 1rem;
    font-weight: 700;
    color: #101010;
    line-height: 1.35;
    margin: 0;
  }

  .comparison-tile__desc {
    font-size: 0.875rem;
    color: #6b7280;
    line-height: 1.55;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .comparison-tile__cta {
    font-size: 0.8rem;
    font-weight: 600;
    color: #EBA541;
    margin-top: 0.25rem;
  }

  /* ── Related ── */
  .related {
    margin-top: 3rem;
    padding-top: 1.75rem;
    border-top: 1px solid #e5e7eb;
  }

  .related h3 {
    font-size: 1rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin: 0 0 1.25rem;
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
  }

  .related-card {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    text-decoration: none;
    border: 1px solid #e5e7eb;
    border-radius: 6px;
    overflow: hidden;
    background: #fff;
    transition: border-color 0.15s;
  }

  .related-card:hover {
    border-color: #EBA541;
    opacity: 1;
  }

  .related-card img,
  .related-card__placeholder {
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    display: block;
  }

  .related-card__placeholder {
    background: #f3f4f6;
  }

  .related-card__title {
    font-size: 0.8rem;
    font-weight: 600;
    color: #101010;
    line-height: 1.35;
    padding: 0 0.75rem 0.75rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  @media (max-width: 600px) {
    .comparison-tile__img,
    .comparison-tile__placeholder {
      width: 120px;
      min-width: 120px;
      height: 100px;
    }

    .comparison-tile__title {
      font-size: 0.9rem;
    }

    .comparison-tile__desc {
      display: none;
    }

    .related-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
