---
import { getCollection, getEntry } from 'astro:content';
import Layout from '../layouts/Layout.astro';

// Latest 5 reviews
const allReviews = await getCollection('reviews', ({ data }) => !data.draft && !!data.heroImage);
const latestReviews = allReviews
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 5);

// Handpicked featured articles
const featuredArticlesRaw = await Promise.all([
  getEntry('guides', 'best-rectangular-watches'),
  getEntry('guides', 'best-seiko-watches-the-ultimate-guide-to-seiko-watches'),
  getEntry('guides', 'best-dive-watches-under-1000'),
]);
const featuredArticles = featuredArticlesRaw.filter((a): a is NonNullable<typeof a> => a != null);

// Handpicked alternatives
const featuredAlternativesRaw = await Promise.all([
  getEntry('alternatives', 'omega-speedmaster-alternatives'),
  getEntry('alternatives', 'rolex-submariner-alternatives'),
  getEntry('alternatives', 'breitling-navitimer-alternatives'),
]);
const featuredAlternatives = featuredAlternativesRaw.filter((a): a is NonNullable<typeof a> => a != null);
---

<Layout title="The Watch Resource — Independent Watch Review Site">
  <main>

    <!-- ── Intro ── -->
    <section class="intro">
      <h1>The Watch Resource — Independent Watch Review Site</h1>
      <p>Welcome to The Watch Resource, an independent watch review site, where a team of watch enthusiasts works tirelessly to keep you up to date&hellip;horologically. Take a look at our educational guides to learn more about the intricate world of wrist watches, or browse our most popular, carefully curated shopping guides like the ones below.</p>
      <p>We hope you have a good time (get it?)</p>
    </section>

    <!-- ── Latest Reviews ── -->
    <section class="section">
      <div class="section-header">
        <h2>Watch Reviews</h2>
        <a href="/reviews/in-depth-watch-reviews/" class="view-all">View all &rarr;</a>
      </div>
      <div class="reviews-grid">
        {latestReviews.map(review => (
          <article class="card">
            <a href={`/reviews/${review.id}/`} class="card-image-wrap">
              <img
                src={review.data.heroImage}
                alt={review.data.title}
                width="600"
                height="400"
                loading="lazy"
                decoding="async"
              />
            </a>
            <div class="card-body">
              <h3><a href={`/reviews/${review.id}/`}>{review.data.title}</a></h3>
              {review.data.description && <p class="card-desc">{review.data.description}</p>}
              <time class="card-date" datetime={review.data.date.toISOString()}>
                {review.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
              </time>
            </div>
          </article>
        ))}
      </div>
    </section>

    <!-- ── Featured Articles ── -->
    <section class="section">
      <div class="section-header">
        <h2>Featured Articles</h2>
      </div>
      <div class="cards-grid">
        {featuredArticles.map(article => (
          <article class="card">
            {article.data.heroImage && (
              <a href={`/guides/${article.id}/`} class="card-image-wrap">
                <img
                  src={article.data.heroImage}
                  alt={article.data.title}
                  width="600"
                  height="400"
                  loading="lazy"
                  decoding="async"
                />
              </a>
            )}
            <div class="card-body">
              <h3><a href={`/guides/${article.id}/`}>{article.data.title}</a></h3>
              {article.data.description && <p class="card-desc">{article.data.description}</p>}
            </div>
          </article>
        ))}
      </div>
    </section>

    <!-- ── Watch Alternatives ── -->
    <section class="section">
      <div class="section-header">
        <h2>Watch Alternatives</h2>
        <a href="/alternatives/alternatives/" class="view-all">View all &rarr;</a>
      </div>
      <div class="cards-grid">
        {featuredAlternatives.map(article => (
          <article class="card">
            {article.data.heroImage && (
              <a href={`/alternatives/${article.id}/`} class="card-image-wrap">
                <img
                  src={article.data.heroImage}
                  alt={article.data.title}
                  width="600"
                  height="400"
                  loading="lazy"
                  decoding="async"
                />
              </a>
            )}
            <div class="card-body">
              <h3><a href={`/alternatives/${article.id}/`}>{article.data.title}</a></h3>
              {article.data.description && <p class="card-desc">{article.data.description}</p>}
            </div>
          </article>
        ))}
      </div>
    </section>

  </main>
</Layout>

<style>
  main {
    max-width: 1200px;
    margin: 0 auto;
    padding: 3rem 1.5rem 5rem;
  }

  /* ── Intro ── */
  .intro {
    max-width: 780px;
    margin-bottom: 4rem;
  }

  .intro h1 {
    font-size: 2rem;
    line-height: 1.2;
    margin: 0 0 1.25rem;
  }

  .intro p {
    font-size: 1rem;
    color: #6b7280;
    line-height: 1.75;
    margin: 0 0 0.75rem;
  }

  /* ── Sections ── */
  .section {
    margin-bottom: 4rem;
  }

  .section-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 1.5rem;
    border-bottom: 2px solid #EBA541;
    padding-bottom: 0.6rem;
  }

  .section-header h2 {
    font-size: 1.25rem;
    font-weight: 700;
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .view-all {
    font-size: 0.85rem;
    color: #EBA541;
    text-decoration: none;
    font-weight: 600;
  }

  .view-all:hover {
    text-decoration: underline;
    opacity: 1;
  }

  /* ── Reviews grid (5 cards: 3 top + 2 bottom) ── */
  .reviews-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  /* ── Featured / Alternatives grid (3 cards) ── */
  .cards-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  /* ── Card ── */
  .card {
    background: #fff;
    border: 1px solid #e5e7eb;
    border-radius: 6px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  .card-image-wrap {
    display: block;
    aspect-ratio: 16 / 9;
    overflow: hidden;
  }

  .card-image-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.3s ease;
  }

  .card:hover .card-image-wrap img {
    transform: scale(1.03);
  }

  .card-body {
    padding: 1rem 1.1rem 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    flex: 1;
  }

  .card-body h3 {
    font-size: 0.95rem;
    font-weight: 700;
    margin: 0;
    line-height: 1.35;
  }

  .card-body h3 a {
    color: #101010;
    text-decoration: none;
  }

  .card-body h3 a:hover {
    color: #EBA541;
    opacity: 1;
  }

  .card-desc {
    font-size: 0.85rem;
    color: #6b7280;
    line-height: 1.6;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-date {
    font-size: 0.78rem;
    color: #9ca3af;
    margin-top: auto;
  }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .reviews-grid,
    .cards-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 580px) {
    .reviews-grid,
    .cards-grid {
      grid-template-columns: 1fr;
    }

    .intro h1 {
      font-size: 1.5rem;
    }
  }
</style>
